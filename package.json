{
  "name": "hyperbalance",
  "version": "0.1.0",
  "description": "Client helpers for funding AO-backed HyperBEAM local ledgers.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./adapters/ao": {
      "types": "./dist/adapters/ao.d.ts",
      "import": "./dist/adapters/ao.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc --noEmit -p tsconfig.json",
    "prepare": "npm run build"
  },
  "keywords": [
    "hyperbeam",
    "ao",
    "ledger",
    "payments",
    "permaweb"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xylophonez/hyperbalance.git"
  },
  "bugs": {
    "url": "https://github.com/xylophonez/hyperbalance/issues"
  },
  "homepage": "https://github.com/xylophonez/hyperbalance#readme",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "sideEffects": false,
  "devDependencies": {
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=18"
  }
}
